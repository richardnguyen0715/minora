# Telegram Bot API token
# Get it from BotFather: https://t.me/botfather
TELEGRAM_TOKEN=your_telegram_token_here

# Telegram Chat ID (optional)
# The group or chat ID where you want the bot to listen
# Get it by sending /start to the bot and checking logs, or use @userinfobot in Telegram
# Example: -1001234567890 (groups have negative IDs)
TELEGRAM_CHAT_ID=your_chat_id_here

# Telegram webhook URL
# This is the URL where Telegram will send updates
# Example: https://your-domain.com/webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# Redis URL for message queue
REDIS_URL=redis://localhost:6379

# Logging level
LOG_LEVEL=INFO

# Application host and port
APP_HOST=0.0.0.0
APP_PORT=8000
